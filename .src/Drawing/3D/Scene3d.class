Public Sub DrawTimer_Timer()

    $hGLA.Refresh

End

Public Sub _new()

    $hGLA = New GLArea(Me) As "gla"
    Me.Proxy = $hGLA
    ' $hda.cached = True
    $hGLA.Expand = True
    $hGLA.Tracking = True
    $hGLA.Mouse = Cursor.CrossHair

    $hGLA.Background = Me.Background 'Color.RGB(jColors[Config.Background][0], jColors[Config.Background][1], jColors[Config.Background][2])
    $hGLA.Foreground = Me.Foreground ' Color.RGB(jColors[Config.Color][0], jColors[Config.Color][1], jColors[Config.Color][2])

End

Public Function UseShader(sVertexShader As String, sColorShader As String) As Boolean

    If ShaderId > 0 Then Return
    ShaderId = glx.LoadShader(sVertexShader, sColorShader)
    If ShaderId = 0 Then
        Return False
    Else
        Return True
    End If

End

Public Sub SetGeneralLigths()

    gl.Enable(GL.LIGHTING)
    gl.Enable(GL.LIGHT0)
    gl.Lightfv(GL.LIGHT0, GL.SPECULAR, [0.4, 0.4, 0.4, 1])
    gl.Lightfv(GL.LIGHT0, GL.DIFFUSE, [1, 1, 1, 1])
    ' gl.Enable(GL.NORMALIZE)
    ' gl.Enable(GL.DEPTH_TEST)
    ' gl.ClearColor(1, 1, 1, 1)
    ' gl.Lightfv(gl.LIGHT0, gl.POSITION, [glcam.Position.x, glcam.Position.y, glcam.Position.z])
    ' gl.LightModeli(GL.LIGHT_MODEL_TWO_SIDE, 1) ' Turn on two-sided lighting.
    ' '
    ' ' gl.LightModelfv(gl.LIGHT_MODEL_AMBIENT, [0.15, 0.15, 0.15, 1])
    ' gl.LightModeli(gl.LIGHT_MODEL_LOCAL_VIEWER, 1)

End

