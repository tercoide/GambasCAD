' Gambas class file

' Describe un VBO

' lines
Public Vertex As New Float[]
Public Colors As New Float[]

' triangles
Public VertexTriangle As New Float[]
Public ColorsTriangle As New Float[]

' points
Public VertexPoints As New Float[]
Public ColorsPoints As New Float[]

Public Normals As New Float[]
Public TextureUV As New Float[]

Public IdNormals As Integer

Public IdColors As Integer
Public IdVertex As Integer

Public IdColorsPoints As Integer
Public IdVertexPoints As Integer

Public IdColorsTriangle As Integer
Public IdVertexTriangle As Integer

Public UseNormals As Boolean = False
Public UseTexture As Boolean = False

Public Sub _new()

End

Public Sub _free()

    If glx.glIsBuffer(IdVertex) Then glx.glDeleteBuffers(1, VarPtr(IdVertex))
    If glx.glIsBuffer(IdColors) Then glx.glDeleteBuffers(1, VarPtr(IdColors))

    If glx.glIsBuffer(IdVertexTriangle) Then glx.glDeleteBuffers(1, VarPtr(IdVertexTriangle))
    If glx.glIsBuffer(IdColorsTriangle) Then glx.glDeleteBuffers(1, VarPtr(IdColorsTriangle))

    If glx.glIsBuffer(IdVertexpoints) Then glx.glDeleteBuffers(1, VarPtr(IdVertexPoints))
    If glx.glIsBuffer(IdColorsPoints) Then glx.glDeleteBuffers(1, VarPtr(IdColorsPoints))

End

Public Sub Clear()

    If glx.glIsBuffer(IdVertex) Then glx.glDeleteBuffers(1, VarPtr(IdVertex))
    If glx.glIsBuffer(IdColors) Then glx.glDeleteBuffers(1, VarPtr(IdColors))

    If glx.glIsBuffer(IdVertexTriangle) Then glx.glDeleteBuffers(1, VarPtr(IdVertexTriangle))
    If glx.glIsBuffer(IdColorsTriangle) Then glx.glDeleteBuffers(1, VarPtr(IdColorsTriangle))

    If glx.glIsBuffer(IdVertexPoints) Then glx.glDeleteBuffers(1, VarPtr(IdVertexPoints))
    If glx.glIsBuffer(IdColorsPoints) Then glx.glDeleteBuffers(1, VarPtr(IdColorsPoints))

    colors.Clear
    Vertex.Clear

    ColorsTriangle.Clear
    VertexTriangle.Clear

    ColorsPoints.Clear
    VertexPoints.Clear

    Normals.Clear
    TextureUV.Clear

End

Public Sub SendBuffersToGPU(Optional mode As Integer = glx.STATIC_DRAW)

    _free()
    IdVertex = glx.createVBO(Vertex.Data, Vertex.Count * SizeOf(Vertex.Type), mode)
    IdColors = glx.createVBO(colors.Data, colors.Count * SizeOf(colors.Type), mode)
    IdVertexTriangle = glx.createVBO(VertexTriangle.Data, VertexTriangle.Count * SizeOf(VertexTriangle.Type), mode)
    IdColorsTriangle = glx.createVBO(ColorsTriangle.Data, ColorsTriangle.Count * SizeOf(ColorsTriangle.Type), mode)
    IdVertexPoints = glx.createVBO(VertexPoints.Data, VertexPoints.Count * SizeOf(VertexPoints.Type), mode)
    IdColorsPoints = glx.createVBO(ColorsPoints.Data, ColorsPoints.Count * SizeOf(ColorsPoints.Type), mode)

End

Public Sub Draw()

    ' -------lines----------------------------------------------------

    glx.glEnableClientState(glx.VERTEX_ARRAY)
    glx.glEnableClientState(glx.COLOR_ARRAY)

    glx.glBindBuffer(gl.ARRAY_BUFFER, IdVertex)
    glx.glVertexPointer(3, gl.DOUBLE, 0, 0) '' ojo con el tipo d datos gbFLOAT = glDOUBLE

    glx.glBindBuffer(gl.ARRAY_BUFFER, IdColors)
    glx.glColorPointer(3, gl.DOUBLE, 0, 0) '' ojo con el tipo d datos gbFLOAT = glDOUBLE

    glx.glDrawArrays(gl.LINES, 0, Vertex.Count / 2)
    glx.glDisableClientState(glx.VERTEX_ARRAY)
    glx.gldisableClientState(glx.COLOR_ARRAY)

    '--------triangles--------------------------------------------

    glx.glEnableClientState(glx.VERTEX_ARRAY)
    glx.glEnableClientState(glx.COLOR_ARRAY)

    glx.glBindBuffer(gl.ARRAY_BUFFER, IdVertexTriangle)
    glx.glVertexPointer(3, gl.DOUBLE, 0, 0) '' ojo con el tipo d datos gbFLOAT = glDOUBLE

    glx.glBindBuffer(gl.ARRAY_BUFFER, IdColorsTriangle)
    glx.glColorPointer(3, gl.DOUBLE, 0, 0) '' ojo con el tipo d datos gbFLOAT = glDOUBLE

    glx.glDrawArrays(gl.TRIANGLES, 0, VertexTriangle.Count / 2)
    glx.glDisableClientState(glx.VERTEX_ARRAY)
    glx.gldisableClientState(glx.COLOR_ARRAY)

    '--------points--------------------------------------------

    glx.glEnableClientState(glx.VERTEX_ARRAY)
    glx.glEnableClientState(glx.COLOR_ARRAY)

    glx.glBindBuffer(gl.ARRAY_BUFFER, IdVertexpoints)
    glx.glVertexPointer(3, gl.DOUBLE, 0, 0) '' ojo con el tipo d datos gbFLOAT = glDOUBLE

    glx.glBindBuffer(gl.ARRAY_BUFFER, IdColorsPoints)
    glx.glColorPointer(3, gl.DOUBLE, 0, 0) '' ojo con el tipo d datos gbFLOAT = glDOUBLE

    glx.glDrawArrays(gl.POINTS, 0, VertexPoints.Count / 2)
    glx.glDisableClientState(glx.VERTEX_ARRAY)
    glx.gldisableClientState(glx.COLOR_ARRAY)

End
